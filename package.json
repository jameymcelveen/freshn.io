{
  "name": "freshn-io-root",
  "version": "0.1.5",
  "license": "SEE LICENSE IN LICENSE",
  "description": "Private workstation sync engine",
  "private": true,
  "type": "module",
  "bin": {
    "freshn": "./bin/freshn.js"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20.x",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "fresh": "tsx src/index.ts",
    "build": "pnpm --filter @freshn/types build && pnpm --filter @freshn/cli build && pnpm --filter web build",
    "build:types": "pnpm --filter @freshn/types build",
    "build:web": "pnpm --filter web build",
    "build:cli": "pnpm --filter @freshn/cli build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "execa": "^8.0.1",
    "semver": "^7.7.4",
    "smol-toml": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
